{
  "name": "node-ts-fastify-template",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev:db-init": "docker run --name template-local -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=localdb -p 5433:5432 -d postgres:17",
    "dev:db": "docker container start template-local && yarn prisma generate",
    "generate": "prisma generate",
    "migrate:reset": "prisma migrate reset",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "prisma db seed",
    "wipe": "tsx prisma/wipe.ts",
    "lint": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "packageManager": "yarn@4.9.2",
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@faker-js/faker": "^9.7.0",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "prisma": "^6.6.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/client": "^6.6.0",
    "busboy": "^1.6.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "fastify-type-provider-zod": "^4.0.2",
    "reflect-metadata": "^0.2.2",
    "uuid": "^13.0.0",
    "vitest": "^3.2.4",
    "zod": "^3.24.3"
  }
}
